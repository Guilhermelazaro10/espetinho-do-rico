# ====== Espetinho do Rico — env de PRODUÇÃO (VPS) ======
# O setup-vps.sh gera este arquivo com segredos aleatórios. Edite ALLOWED_ORIGINS.

NODE_ENV=production
PORT=3001

# Banco no volume persistente, FORA do código (git pull não toca; Litestream observa)
DATABASE_URL=file:/opt/espetinho/data/pdv.db

# Segredos (gerados pelo setup; NÃO comitar este arquivo)
JWT_SECRET=
PRINT_AGENT_TOKEN=

# Sua URL pública (a mesma do Caddy/Cloudflare)
ALLOWED_ORIGINS=https://pdv.seurestaurante.com.br
ALLOW_LAN_ORIGINS=false

# O backend serve a SPA buildada
FRONTEND_DIST=/opt/espetinho/frontend/dist

# Impressão pela fila: o agente na loja puxa e imprime na térmica de rede
PRINT_MODE=queue
