// Schema do PDV "Espetinho do Rico"
// Banco: SQLite (arquivo local dev.db)
//
// Convenções:
//  - Valores monetários SEMPRE em CENTAVOS (inteiros) — aritmética exata.
//  - SQLite não suporta enums no Prisma: os valores canônicos vivem em
//    src/constantes.js (PAPEIS, STATUS_MESA, TIPOS_PEDIDO) e toda escrita
//    é validada na camada de serviço.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Produto {
  id        Int          @id @default(autoincrement())
  nome      String
  preco     Int // centavos
  categoria String
  ativo     Boolean      @default(true) // soft delete: preserva relatórios passados
  itens     ItemPedido[]

  @@map("produtos")
}

model Mesa {
  id         Int         @id @default(autoincrement())
  numero     Int         @unique
  status     String      @default("LIVRE") // LIVRE | OCUPADA | AGUARDANDO_PAGAMENTO
  taxaAtiva  Boolean     @default(false) @map("taxa_ativa") // taxa de serviço 10% na conta atual
  pedidos    Pedido[]
  pagamentos Pagamento[]

  @@map("mesas")
}

model Pedido {
  id                 Int          @id @default(autoincrement())
  tipo               String       @default("MESA") // MESA | DELIVERY | BALCAO
  mesa               Mesa?        @relation(fields: [mesaId], references: [id])
  mesaId             Int?         @map("mesa_id") // obrigatório só para tipo MESA
  clienteNome        String?      @map("cliente_nome") // DELIVERY e BALCAO
  clienteTelefone    String?      @map("cliente_telefone") // DELIVERY
  clienteEndereco    String?      @map("cliente_endereco") // DELIVERY
  taxaEntrega        Int          @default(0) @map("taxa_entrega") // centavos, DELIVERY
  total              Int          @default(0) // centavos, congelado na criação (itens + entrega)
  taxaServico        Int          @default(0) @map("taxa_servico") // centavos, gravado no fechamento
  status             String       @default("aberto") // aberto | em_preparo | entregue | pago | cancelado
  formaPagamento     String?      @map("forma_pagamento") // dinheiro | cartao | pix | multiplo
  origem             String?      // 'online' (cardápio web) | null (lançado internamente)
  pagamentoPretendido String?     @map("pagamento_pretendido") // pix|cartao|dinheiro — intenção no delivery online
  trocoPara          Int?         @map("troco_para") // centavos, quando dinheiro
  agendadoPara       String?      @map("agendado_para") // rótulo do agendamento (pedido feito com a loja fechada)
  motivoCancelamento String?      @map("motivo_cancelamento")
  criadoEm           DateTime     @default(now()) @map("criado_em")
  itens              ItemPedido[]
  pagamentos         Pagamento[]

  @@index([status])
  @@index([tipo])
  @@index([criadoEm])
  @@map("pedidos")
}

model ItemPedido {
  id            Int     @id @default(autoincrement())
  pedido        Pedido  @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  pedidoId      Int     @map("pedido_id")
  produto       Produto @relation(fields: [produtoId], references: [id])
  produtoId     Int     @map("produto_id")
  quantidade    Int     @default(1)
  precoUnitario Int     @map("preco_unitario") // centavos, congelado no momento da venda
  observacao    String?

  @@map("itens_pedido")
}

// Fonte de verdade da gaveta: cada lançamento de pagamento recebido.
// Pagamentos PARCIAIS de mesa ficam com liquidado=false até o saldo zerar;
// pagamentos de delivery/balcão apontam para o pedido.
model Pagamento {
  id        Int      @id @default(autoincrement())
  mesa      Mesa?    @relation(fields: [mesaId], references: [id])
  mesaId    Int?     @map("mesa_id")
  pedido    Pedido?  @relation(fields: [pedidoId], references: [id])
  pedidoId  Int?     @map("pedido_id")
  forma     String // dinheiro | cartao | pix
  valor     Int // centavos, líquido (troco já descontado)
  liquidado Boolean  @default(true) // false = parcial aguardando o saldo da mesa zerar
  criadoEm  DateTime @default(now()) @map("criado_em")

  @@index([criadoEm])
  @@map("pagamentos")
}

model Usuario {
  id      Int     @id @default(autoincrement())
  nome    String
  pinHash String  @map("pin_hash") // scrypt salt:hash
  papel   String // GERENTE | GARCOM
  ativo   Boolean @default(true) // desligamento preserva histórico/auditoria

  @@map("usuarios")
}

// Trilha de auditoria de ações sensíveis (pagamentos, cancelamentos, remoções)
model Auditoria {
  id       Int      @id @default(autoincrement())
  usuario  String // snapshot "nome (papel)" — imutável mesmo se o usuário mudar
  acao     String
  detalhe  String
  criadoEm DateTime @default(now()) @map("criado_em")

  @@index([criadoEm])
  @@map("auditoria")
}

// Turno de caixa (gaveta física). Um aberto por vez.
model Caixa {
  id            Int              @id @default(autoincrement())
  status        String           @default("aberto") // aberto | fechado
  fundoAbertura Int              @default(0) @map("fundo_abertura") // centavos
  abertoPor     String           @map("aberto_por")
  abertoEm      DateTime         @default(now()) @map("aberto_em")
  fechadoPor    String?          @map("fechado_por")
  fechadoEm     DateTime?        @map("fechado_em")
  valorContado  Int?             @map("valor_contado") // contagem cega no fechamento
  diferenca     Int? // contado - esperado (sobra +/- falta)
  observacao    String?
  movimentos    MovimentoCaixa[]

  @@index([status])
  @@map("caixas")
}

// Sangria (retirada) ou suprimento (reforço de troco) durante o turno
model MovimentoCaixa {
  id       Int      @id @default(autoincrement())
  caixa    Caixa    @relation(fields: [caixaId], references: [id], onDelete: Cascade)
  caixaId  Int      @map("caixa_id")
  tipo     String // sangria | suprimento
  valor    Int // centavos
  motivo   String
  por      String
  criadoEm DateTime @default(now()) @map("criado_em")

  @@map("movimentos_caixa")
}

// Fila de impressão (modo nuvem): o backend enfileira o cupom já formatado e
// um agente na loja puxa, imprime na térmica de rede e confirma.
model PrintJob {
  id           Int      @id @default(autoincrement())
  tipo         String // cupom | pre_conta | gaveta
  refId        Int?     @map("ref_id") // pedido/mesa de referência
  conteudo     String // linhas do cupom já formatadas (separadas por \n)
  abrirGaveta  Boolean  @default(false) @map("abrir_gaveta")
  status       String   @default("pendente") // pendente | impresso | erro
  tentativas   Int      @default(0)
  erro         String?
  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  @@index([status])
  @@map("print_jobs")
}
