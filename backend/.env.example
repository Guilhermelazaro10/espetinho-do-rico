# ====== Espetinho do Rico — variáveis do backend ======
# Copie para .env e ajuste. Em produção (VPS), defina via ambiente do sistema.

# Banco SQLite (arquivo local). Em produção aponte para o volume persistente.
DATABASE_URL="file:./dev.db"

# Porta da API
PORT=3001

# Segredo dos tokens JWT. NUNCA use o padrão em produção.
# Os launchers (Electron/LAN) geram um por instalação; na VPS defina um forte:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="troque-esta-chave-em-producao"

# Ambiente: development | production
NODE_ENV=production

# Origens permitidas no CORS (separadas por vírgula). Na VPS, a URL pública:
ALLOWED_ORIGINS="http://localhost:5173,http://127.0.0.1:5173"

# Permite origens de IP privado (LAN) no CORS — true no modo desktop/LAN.
ALLOW_LAN_ORIGINS=true

# Pasta do build do frontend para o backend servir a SPA (opcional).
# FRONTEND_DIST=/caminho/para/frontend/dist

# ====== Impressão ======
# local: imprime direto na máquina (desktop). queue: enfileira p/ o agente (nuvem).
PRINT_MODE=local

# Interface da térmica no modo 'local' (no modo 'queue' quem usa é o agente).
# PRINTER_INTERFACE=tcp://192.168.0.50:9100

# Token compartilhado com o agente de impressão (modo 'queue'). Gere um forte:
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
PRINT_AGENT_TOKEN=
